# LLM Providers
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Model Configuration
LLM_PROVIDER=anthropic
LLM_MODEL=claude-haiku-4-5
# Options: claude-haiku-4-5 (fast/cheap), claude-sonnet-4-6 (higher quality)
EMBEDDING_MODEL=text-embedding-3-small
LLM_TEMPERATURE=0.2

# LangSmith (optional)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=lsv2_...
LANGCHAIN_PROJECT=qe-platform

# Weights & Biases (optional)
WANDB_API_KEY=...
WANDB_PROJECT=qe-platform
WANDB_ENTITY=...

# Demo mode (replays pre-recorded SSE — no LLM calls)
DEMO_MODE=false

# Execution
MAX_CONCURRENT_TESTS=5
SELF_HEAL_MAX_RETRIES=2
DEDUP_SIMILARITY_THRESHOLD=0.92
